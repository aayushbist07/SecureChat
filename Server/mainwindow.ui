  <property name="styleSheet">
   <string notr="true">
/* ── Base ─────────────────────────────────────────────── */
QMainWindow, QWidget {
    background-color: #1c1f27;
    color: #d4dbe8;
    font-family: &quot;Segoe UI&quot;, sans-serif;
    font-size: 13px;
}

/* ── Left panel ───────────────────────────────────────── */
QFrame#leftPanel {
    background-color: #14171e;
    border-right: 1px solid #2a2e3d;
}

/* ── Section labels ───────────────────────────────────── */
QLabel#label_UsersHeader,
QLabel#label_LogHeader {
    font-size: 10px;
    font-weight: bold;
    letter-spacing: 1px;
    color: #4a5a72;
    background: transparent;
    padding: 0px 4px;
}

/* ── User list widget ─────────────────────────────────── */
QListWidget#listWidget_Users {
    background-color: #14171e;
    border: none;
    outline: none;
    font-size: 13px;
    color: #c8d4e3;
}
QListWidget#listWidget_Users::item {
    padding: 6px 8px;
    border-bottom: 1px solid #1e2330;
}
QListWidget#listWidget_Users::item:selected {
    background-color: #1e2b20;
    color: #7ecfb3;
}

/* ── Event log ────────────────────────────────────────── */
QTextEdit#textEdit_Event_Log {
    background-color: #11131a;
    border: 1px solid #1e2330;
    border-radius: 6px;
    color: #4a8a72;
    font-family: &quot;Consolas&quot;, &quot;Courier New&quot;, monospace;
    font-size: 11px;
    padding: 6px;
}

/* ── Center message log ───────────────────────────────── */
QTextEdit#textEdit_Client_Messages {
    background-color: #181b23;
    border: 1px solid #2a2e3d;
    border-radius: 8px;
    color: #d4dbe8;
    font-size: 13px;
    padding: 10px;
}

/* ── Bottom bar ───────────────────────────────────────── */
QFrame#bottomBar {
    background-color: #14171e;
    border-top: 1px solid #2a2e3d;
}

QComboBox#comboBox_Client_List,
QComboBox#combobox2_Send_Message_type {
    background-color: #1e2330;
    border: 1px solid #2e3650;
    border-radius: 6px;
    color: #c8d4e3;
    padding: 4px 8px;
    font-size: 12px;
    min-height: 32px;
}
QComboBox#comboBox_Client_List:hover,
QComboBox#combobox2_Send_Message_type:hover {
    border-color: #3d7a5e;
}
QComboBox::drop-down {
    border: none;
    width: 20px;
}
QComboBox QAbstractItemView {
    background-color: #1e2330;
    border: 1px solid #2e3650;
    color: #c8d4e3;
    selection-background-color: #1e2b20;
    selection-color: #7ecfb3;
}

QLineEdit#lineEdit_send_message {
    background-color: #1e2330;
    border: 1px solid #2e3650;
    border-radius: 6px;
    color: #d4dbe8;
    padding: 4px 10px;
    font-size: 13px;
    min-height: 32px;
}
QLineEdit#lineEdit_send_message:focus {
    border-color: #3d7a5e;
}

QPushButton#push_button_Send {
    background-color: #2d5e47;
    color: #a8e6cc;
    border: none;
    border-radius: 6px;
    padding: 6px 18px;
    font-size: 13px;
    font-weight: bold;
    min-height: 32px;
}
QPushButton#push_button_Send:hover {
    background-color: #3d7a5e;
}
QPushButton#push_button_Send:pressed {
    background-color: #1e4a35;
}

/* ── Status bar ───────────────────────────────────────── */
QStatusBar {
    background-color: #11131a;
    color: #4a6a58;
    font-size: 11px;
    border-top: 1px solid #1e2330;
}
